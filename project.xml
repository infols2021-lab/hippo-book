<file path="app/(app)/materials/materials.css">
/* app/(app)/materials/materials.css */

/* фон страницы как в профиле/логине */
.materials-page {
  min-height: 100vh;
  padding: 22px 0;

  background-color: #eaf7ff;
  background-image:
    radial-gradient(1200px 700px at 15% 10%, rgba(78, 205, 196, 0.18), transparent 60%),
    radial-gradient(1100px 700px at 85% 20%, rgba(110, 190, 255, 0.22), transparent 62%),
    linear-gradient(180deg, #f5fbff 0%, #d7eefc 58%, #f0fbff 100%);
  background-attachment: fixed;

  color: #1f2937;
}

.materials-page::after{
  content:"";
  position: fixed;
  inset: 0;
  pointer-events: none;
  background: radial-gradient(900px 520px at 50% 35%, rgba(0, 0, 0, 0.03), transparent 60%);
}

.materials-container {
  width: 95%;
  max-width: 1200px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}

/* Заголовок секции (h3) приятнее */
.materials-title {
  margin: 0 0 6px 0;
  font-size: 18px;
  font-weight: 1000;
  color: rgba(44, 62, 80, 0.86);
}

.materials-subtitle {
  margin: 0 0 14px 0;
  font-size: 13px;
  font-weight: 850;
  color: rgba(44, 62, 80, 0.60);
}

/* “Стеклянная” плашка под табами */
.materials-panel {
  background: rgba(255,255,255,0.62);
  border: 1px solid rgba(255,255,255,0.75);
  box-shadow: 0 20px 60px rgba(15, 65, 95, 0.14);
  backdrop-filter: blur(14px);
  border-radius: 22px;
  padding: 14px;
  margin-top: 14px;
}

/* Tabs */
.materials-tabs {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  padding: 8px;

  background: rgba(255,255,255,0.60);
  border: 1px solid rgba(255,255,255,0.75);
  backdrop-filter: blur(14px);
  border-radius: 999px;

  box-shadow: 0 16px 40px rgba(15, 65, 95, 0.12);
  margin: 14px 0 16px;
}

.material-tab {
  padding: 10px 16px;
  border: 0;
  border-radius: 999px;
  cursor: pointer;

  font-size: 14px;
  font-weight: 1000;
  color: rgba(44, 62, 80, 0.70);
  background: rgba(255,255,255,0.55);
  border: 1px solid rgba(110,190,255,0.18);

  transition: transform .12s ease, filter .12s ease, background .12s ease;
  box-shadow: 0 14px 26px rgba(15,65,95,0.10);
}

.material-tab:hover {
  transform: translateY(-2px);
  filter: brightness(1.02);
}

.material-tab:active {
  transform: translateY(0px);
  filter: brightness(0.98);
}

.material-tab.active {
  color: white;
  background: linear-gradient(135deg, rgba(78, 205, 196, 0.95), rgba(110, 190, 255, 0.92));
  border-color: transparent;
  box-shadow: 0 18px 36px rgba(78,205,196,0.18);
}

.materials-section {
  display: none;
}

.materials-section.active {
  display: block;
}

/* Grid */
.materials-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
  gap: 18px;
  margin-top: 14px;
}

/* Card */
.material-card {
  position: relative;
  cursor: pointer;

  border-radius: 18px;
  padding: 16px;

  background: rgba(255,255,255,0.70);
  border: 1px solid rgba(255,255,255,0.80);
  backdrop-filter: blur(14px);

  box-shadow: 0 16px 46px rgba(15, 65, 95, 0.14);
  transition: transform .12s ease, box-shadow .12s ease, border-color .12s ease, filter .12s ease;
}

.material-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 24px 68px rgba(15, 65, 95, 0.18);
  border-color: rgba(78, 205, 196, 0.45);
  filter: brightness(1.01);
}

/* ✅ FIX: обложка теперь держит 16:9, а не фикс. высоту — 16:9 картинки не режутся на широких карточках */
.material-cover {
  width: 100%;
  aspect-ratio: 16 / 9;
  border-radius: 14px;
  margin-bottom: 12px;

  display: flex;
  align-items: center;
  justify-content: center;

  color: white;
  font-size: 46px;
  font-weight: 1000;

  overflow: hidden;
  background: linear-gradient(135deg, rgba(110, 190, 255, 0.92), rgba(78, 205, 196, 0.92));
  box-shadow: inset 0 0 0 1px rgba(255,255,255,0.35);
}

.material-cover img {
  width: 100%;
  height: 100%;
  object-fit: contain;     /* ✅ FIX: показываем 16:9 целиком, без “жесткой” обрезки */
  object-position: center; /* на всякий */
  border-radius: 14px;
  display: block;
}

.material-title {
  font-size: 16px;
  font-weight: 1000;
  margin-bottom: 6px;
  color: rgba(44, 62, 80, 0.86);
}

.material-description {
  color: rgba(44, 62, 80, 0.62);
  font-size: 13px;
  font-weight: 800;
  margin-bottom: 10px;
  line-height: 1.35;
}

/* Progress */
.progress-bar {
  width: 100%;
  height: 8px;
  background: rgba(44, 62, 80, 0.10);
  border-radius: 999px;
  overflow: hidden;
  margin: 10px 0 8px;
}

.progress-fill {
  height: 100%;
  width: 0%;
  background: linear-gradient(135deg, rgba(78, 205, 196, 0.95), rgba(110, 190, 255, 0.92));
  border-radius: 999px;
  transition: width 0.3s ease;
}

.material-stats {
  display: flex;
  justify-content: space-between;
  align-items: center;

  font-size: 12px;
  font-weight: 900;
  color: rgba(44, 62, 80, 0.55);
}

.material-stats .pct {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 4px 10px;
  border-radius: 999px;

  background: rgba(78, 205, 196, 0.14);
  border: 1px solid rgba(78, 205, 196, 0.22);
  color: rgba(44, 62, 80, 0.78);
}

/* Locked */
.material-card.locked {
  cursor: not-allowed;
  filter: grayscale(1) saturate(0.6);
  opacity: 0.85;
