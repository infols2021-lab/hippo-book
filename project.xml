    border-radius: 0;
  }

  .header {
    flex-direction: column;
    gap: 15px;
    text-align: center;
  }

  .logo { justify-content: center; }

  .nav {
    justify-content: center;
    flex-wrap: wrap;
  }

  .profile-avatar {
