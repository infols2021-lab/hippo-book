<file path="app/(app)/profile/profile.css">
/* app/(app)/profile/profile.css */

/* ===== Hard reset for this page (fix top stripe) ===== */
html,
body {
  margin: 0 !important;
  padding: 0 !important;
  background: #c9efff; /* ультра ярче база */
}

body {
  overflow-x: hidden;
}

/* ===== Page background (base blue + optional PNG overlay) ===== */
#profileBody {
  margin: 0;
  padding: 0;
  min-height: 100vh;

  /* ✅ НОВЫЕ ШРИФТЫ (читабельно на мобиле и ПК) */
  font-family:
    "Inter",
    ui-sans-serif,
    system-ui,
    -apple-system,
    "Segoe UI",
    Roboto,
    Arial,
    "Noto Sans",
    "Helvetica Neue",
    sans-serif;

  font-size: 16px;
  line-height: 1.35;
  letter-spacing: 0.01em;

  text-rendering: geometricPrecision;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;

  /* ✅ текст ещё темнее */
  color: #07172e;

  /* ✅ фон ярче и насыщеннее */
  background-color: #c9efff;
  background-image:
    var(--profile-overlay, none),
    radial-gradient(1200px 720px at 14% 10%, rgba(0, 180, 255, 0.42), transparent 60%),
    radial-gradient(1100px 740px at 86% 18%, rgba(0, 255, 205, 0.34), transparent 62%),
    linear-gradient(180deg, #f9feff 0%, #bfe6ff 54%, #e9fbff 100%);
  background-repeat: no-repeat, no-repeat, no-repeat, no-repeat;
  background-position: center, center, center, center;
  background-size: cover, cover, cover, cover;
  background-attachment: fixed, fixed, fixed, fixed;
}

/* ✅ почти убрали “вуаль” */
#profileBody::after {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  background: radial-gradient(900px 520px at 50% 35%, rgba(0, 0, 0, 0.008), transparent 64%);
  z-index: 0;
}

/* ✅ анти-слипание мелкого текста */
.brand-subtitle,
.streak-chip-sub,
.profile-email,
.mini-cap,
.mini-stat-label,
.progress-sub,
.info-li,
.section-title,
.streak-summary-key {
  line-height: 1.35;
  letter-spacing: 0.02em;
}

/* ✅ основной текст — мягче трекинг */
.progress-title,
.mini-val,
.brand-title,
.profile-name {
  letter-spacing: 0.005em;
}

/* ===== Container ===== */
#profileBody .container {
  width: 95%;
  max-width: 1220px;
  margin: 22px auto 28px;
  position: relative;
  z-index: 1;
}

/* ===== Topbar ===== */
.profile-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;

  padding: 14px 16px;
  border-radius: 22px;

  /* ✅ больше “чистого белого”, меньше тумана */
  background: rgba(255, 255, 255, 0.90);
  border: 1px solid rgba(255, 255, 255, 0.96);
  box-shadow: 0 18px 55px rgba(6, 30, 58, 0.14);

  /* ✅ меньше blur => чётче */
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.brand {
  display: flex;
  align-items: center;
  gap: 12px;
  min-width: 240px;
}

.brand-mark {
  width: 54px;
  height: 54px;
  border-radius: 14px;
  display: grid;
  place-items: center;

  font-weight: 900;
  letter-spacing: 0.5px;
  color: white;

  /* ✅ ещё более сочный градиент */
  background: linear-gradient(135deg, rgba(20, 140, 255, 0.99), rgba(0, 235, 200, 0.99));
  box-shadow: 0 14px 34px rgba(0, 235, 200, 0.24);
}

.brand-title {
  font-size: 20px;
  font-weight: 1000;
  line-height: 1.1;
  color: #07172e;
}

.brand-subtitle {
  font-size: 12px;
  font-weight: 900;
  color: rgba(7, 23, 46, 0.62);
  margin-top: 2px;
}

.top-actions {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.nav-pill {
  display: inline-flex;
  align-items: center;
  gap: 10px;

  padding: 10px 16px;
  border-radius: 16px;
  border: 0;
  cursor: pointer;

  font-weight: 1000;
  font-size: 14px;
  color: white;

  box-shadow: 0 14px 30px rgba(6, 30, 58, 0.14);
  transition: transform 0.12s ease, filter 0.12s ease;
  user-select: none;
  text-decoration: none;
  white-space: nowrap;
}

.nav-pill:hover {
  transform: translateY(-2px);
  filter: brightness(1.07);
}

.nav-pill:active {
  transform: translateY(0px);
  filter: brightness(0.98);
}

.nav-pill--info {
  background: linear-gradient(135deg, rgba(25, 145, 255, 0.99), rgba(110, 215, 255, 0.99));
}

.nav-pill--materials {
  background: linear-gradient(135deg, rgba(0, 235, 200, 0.99), rgba(60, 255, 230, 0.99));
}

.nav-pill--logout {
  background: linear-gradient(135deg, rgba(255, 70, 70, 0.99), rgba(255, 140, 140, 0.99));
}

/* ===== Streak chip in topbar (larger + clickable) ===== */
.streak-chip {
  min-width: 156px;
  height: 52px;
  border-radius: 16px;
  padding: 8px 12px;

  display: inline-grid;
  grid-template-columns: 32px auto;
  grid-template-rows: 1fr 1fr;
  column-gap: 9px;
  align-items: center;

  color: #fff;
  border: 1px solid rgba(255, 255, 255, 0.35);
  box-shadow: 0 14px 30px rgba(15, 65, 95, 0.14);
  user-select: none;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.streak-chip--button {
  appearance: none;
  -webkit-appearance: none;
  background-clip: padding-box;
  cursor: pointer;
  text-align: left;
  font: inherit;
  transition: transform 0.12s ease, filter 0.12s ease, box-shadow 0.12s ease;
}

.streak-chip--button:hover {
  transform: translateY(-2px);
  filter: brightness(1.03);
  box-shadow: 0 18px 34px rgba(15, 65, 95, 0.18);
}

.streak-chip--button:active {
  transform: translateY(0);
  filter: brightness(0.99);
}

.streak-chip--button:focus-visible {
  outline: 3px solid rgba(255, 255, 255, 0.65);
  outline-offset: 2px;
}

.streak-chip-icon {
  grid-row: 1 / span 2;
  width: 32px;
  height: 32px;
  border-radius: 10px;
  display: grid;
  place-items: center;
  background: rgba(255, 255, 255, 0.2);
  font-size: 17px;
  line-height: 1;
  overflow: hidden;
}

.streak-chip-main {
  display: inline-flex;
  align-items: baseline;
  gap: 4px;
  line-height: 1;
}

.streak-chip-value {
  font-size: 19px;
  font-weight: 1000;
  letter-spacing: 0.2px;
}

.streak-chip-unit {
  font-size: 12px;
  font-weight: 900;
  opacity: 0.95;
}

.streak-chip-sub {
  font-size: 11px;
  font-weight: 900;
  line-height: 1;
  opacity: 0.96;
  white-space: nowrap;
}

.streak-chip--loading {
  opacity: 0.9;
}

.streak-chip--none {
  background: linear-gradient(135deg, rgba(148, 163, 184, 0.95), rgba(176, 190, 208, 0.95));
}

/* ✅ BRONZE — жирная бронза */
.streak-chip--bronze {
  background: linear-gradient(135deg, rgba(184, 115, 51, 0.98), rgba(224, 169, 109, 0.96));
}

/* silver — как было */
.streak-chip--silver {
  background: linear-gradient(135deg, rgba(148, 163, 184, 0.95), rgba(203, 213, 225, 0.95));
}

/* ✅ GOLD — прям золото */
.streak-chip--gold {
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.98), rgba(255, 215, 102, 0.98));
}

/* platinum — как было */
.streak-chip--platinum {
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.95), rgba(129, 140, 248, 0.95));
}

/* ✅ DIAMOND — алмаз, чтобы светилось */
.streak-chip--diamond {
  background: linear-gradient(135deg, rgba(6, 182, 212, 0.98), rgba(59, 130, 246, 0.98));
  box-shadow:
    0 14px 30px rgba(59, 130, 246, 0.22),
    0 0 0 3px rgba(6, 182, 212, 0.14),
    0 0 28px rgba(59, 130, 246, 0.18);
}

/* ✅ LEGENDARY — разноцветный градиент + свечение */
@keyframes legendaryShift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

.streak-chip--legendary {
  background: linear-gradient(
    135deg,
    rgba(124, 58, 237, 0.98),
    rgba(37, 99, 235, 0.98),
    rgba(6, 182, 212, 0.98),
    rgba(236, 72, 153, 0.98)
  );
  background-size: 220% 220%;
  animation: legendaryShift 6s ease-in-out infinite;
  box-shadow:
    0 16px 34px rgba(124, 58, 237, 0.20),
    0 0 0 3px rgba(236, 72, 153, 0.12),
    0 0 34px rgba(37, 99, 235, 0.18);
}

/* ===== Layout panels ===== */
.profile-layout {
  display: grid;
  grid-template-columns: 380px 1fr;
  gap: 18px;
  margin-top: 18px;
}

.panel {
  border-radius: 26px;

  /* ✅ ещё менее “молочное” стекло */
  background: rgba(255, 255, 255, 0.86);
  border: 1px solid rgba(255, 255, 255, 0.97);
  box-shadow: 0 22px 70px rgba(6, 30, 58, 0.14);

  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  padding: 16px;
}

/* ===== Left profile panel ===== */
.profile-card {
  border-radius: 22px;
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(255, 255, 255, 0.98);
  box-shadow: inset 0 0 0 1px rgba(25, 145, 255, 0.10);
  padding: 18px 16px 16px;
  text-align: center;
}

/* ✅ Bigger avatar circle (как на твоём скрине) */
.avatar-circle {
  width: 268px;
  height: 268px;
  margin: 6px auto 16px;
  border-radius: 999px;
  background: linear-gradient(180deg, rgba(110, 190, 255, 0.25), rgba(78, 205, 196, 0.18));
  display: grid;
  place-items: center;
  box-shadow: 0 22px 60px rgba(6, 30, 58, 0.12);
  border: 8px solid rgba(255, 255, 255, 0.95);
}

/* ─────────────────────────────────────────────────────────────
   Avatar outer circle theming by tier
   ───────────────────────────────────────────────────────────── */
.avatar-circle--none {
  background: inherit;
}

.avatar-circle.avatar-circle--bronze {
  background: radial-gradient(
    circle at 35% 30%,
    rgba(255, 232, 204, 0.58),
    rgba(184, 115, 51, 0.24) 55%,
    rgba(224, 169, 109, 0.20) 100%
  );
  box-shadow:
    0 24px 62px rgba(184, 115, 51, 0.16),
    0 0 0 6px rgba(224, 169, 109, 0.10);
}

.avatar-circle.avatar-circle--gold {
  background: radial-gradient(
    circle at 35% 30%,
    rgba(255, 246, 214, 0.60),
    rgba(245, 158, 11, 0.26) 55%,
    rgba(255, 215, 102, 0.20) 100%
  );
  box-shadow:
    0 24px 62px rgba(245, 158, 11, 0.16),
    0 0 0 6px rgba(255, 215, 102, 0.12);
}

.avatar-circle.avatar-circle--diamond {
  background: radial-gradient(
    circle at 35% 30%,
    rgba(219, 255, 255, 0.60),
    rgba(6, 182, 212, 0.24) 50%,
    rgba(59, 130, 246, 0.20) 100%
  );
  box-shadow:
    0 24px 68px rgba(59, 130, 246, 0.18),
    0 0 0 6px rgba(6, 182, 212, 0.14),
    0 0 50px rgba(59, 130, 246, 0.16);
}

.avatar-circle.avatar-circle--legendary {
  background: linear-gradient(
    135deg,
    rgba(124, 58, 237, 0.32),
    rgba(37, 99, 235, 0.28),
    rgba(6, 182, 212, 0.24),
    rgba(236, 72, 153, 0.28)
  );
  background-size: 220% 220%;
  animation: legendaryShift 6s ease-in-out infinite;
  box-shadow:
    0 26px 74px rgba(124, 58, 237, 0.18),
    0 0 0 6px rgba(6, 182, 212, 0.14),
    0 0 58px rgba(236, 72, 153, 0.14);
}

.avatar-inner {
  width: 228px;
  height: 228px;
  border-radius: 999px;
  background: radial-gradient(
    circle at 40% 30%,
    #ffffff 0%,
    rgba(255, 255, 255, 0.90) 65%,
    rgba(255, 255, 255, 0.84) 100%
  );
  display: grid;
  place-items: center;
  border: 1px solid rgba(25, 145, 255, 0.16);
  position: relative;
}

.avatar-icon {
  width: 100%;
  height: 100%;
  display: grid;
  place-items: stretch;
  position: relative;
  user-select: none;
  border-radius: 999px;
  overflow: hidden;
  isolation: isolate;
}

.avatar-icon-bg {
  position: absolute;
  inset: 22px;
  border-radius: 999px;
  background: radial-gradient(
    circle at 32% 28%,
    rgba(255, 255, 255, 0.98),
    rgba(225, 250, 255, 0.78) 55%,
    rgba(190, 235, 255, 0.56) 100%
  );
  filter: blur(0.12px);
  z-index: 0;
}

.profile-name {
  font-size: 24px;
  font-weight: 1000;
  color: #07172e;
  margin-top: 8px;
}

/* ===== title slot under name ===== */
.profile-title-slot {
  margin-top: 8px;
  margin-left: auto;
  margin-right: auto;
  max-width: 290px;

  display: inline-flex;
  align-items: center;
  gap: 8px;

  padding: 7px 12px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.96);
  border: 1px solid rgba(25, 145, 255, 0.22);
  box-shadow: 0 10px 24px rgba(6, 30, 58, 0.06);
}

.profile-title-slot-icon {
  width: 20px;
  height: 20px;
  border-radius: 999px;
  display: grid;
  place-items: center;
  background: rgba(25, 145, 255, 0.16);
  font-size: 11px;
  flex: 0 0 auto;
}

.profile-title-slot-text {
  min-width: 0;
  font-size: 12px;
  font-weight: 900;
  color: rgba(7, 23, 46, 0.82);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.profile-email {
  margin-top: 6px;
  font-size: 13px;
  font-weight: 900;
  color: rgba(7, 23, 46, 0.60);
}

/* ===== Generic visual renderer for streak icon (image -> emoji fallback) ===== */
.streak-visual {
  display: inline-grid;
  place-items: center;
  width: 100%;
  height: 100%;
  line-height: 1;
  user-select: none;
}

.streak-visual__img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center;
  -webkit-user-drag: none;
  user-select: none;
}

.streak-visual__emoji {
  display: inline-grid;
  place-items: center;
  width: 100%;
  height: 100%;
  line-height: 1;
}

/* avatar version */
.streak-visual--avatar {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 100%;
  border-radius: 999px;
  overflow: hidden;
  display: grid;
  place-items: center;
  justify-self: stretch;
  align-self: stretch;
}

/* ✅ Тут ключ: меньше padding => картинка реально большая */
.avatar-icon .streak-visual__img--avatar {
  width: 100%;
  height: 100%;
  box-sizing: border-box;
  padding: 8%;
  object-fit: contain;
  object-position: center center;
  max-width: none;
  max-height: none;
  filter: drop-shadow(0 10px 28px rgba(45, 80, 120, 0.18));
  transform: none;
}

.avatar-icon .streak-visual__emoji--avatar {
  font-size: clamp(74px, 16vw, 124px);
  text-shadow: 0 10px 28px rgba(45, 80, 120, 0.18);
  transform: none;
}

/* top chip version */
.streak-visual--chip {
  width: 100%;
  height: 100%;
}

.streak-visual__img--chip {
  width: 22px;
  height: 22px;
  object-fit: contain;
  filter: drop-shadow(0 2px 5px rgba(0, 0, 0, 0.12));
}

.streak-visual__emoji--chip {
  font-size: 17px;
}

/* badge version */
.streak-mini-badge-icon {
  width: 18px;
  height: 18px;
  display: inline-grid;
  place-items: center;
  flex: 0 0 auto;
  line-height: 1;
}

.streak-visual--badge {
  width: 18px;
  height: 18px;
}

.streak-visual__img--badge {
  width: 18px;
  height: 18px;
  object-fit: contain;
  filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.14));
}

.streak-visual__emoji--badge {
  font-size: 14px;
}

/* ===== Bigger centered streak badge on avatar ===== */
.streak-mini-badge {
  position: absolute;
  left: 50%;
  right: auto;
  bottom: -16px;
  transform: translateX(-50%);

  min-width: 74px;
  height: 40px;
  border-radius: 999px;
  padding: 6px 16px;

  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0;

  border: 2px solid rgba(255, 255, 255, 0.95);
  box-shadow: 0 10px 22px rgba(15, 65, 95, 0.18);
  color: #fff;
  font-size: 14px;
  font-weight: 900;
  line-height: 1;

  cursor: pointer;
  appearance: none;
  -webkit-appearance: none;
  transition: transform 0.12s ease, filter 0.12s ease, box-shadow 0.12s ease;
}

.streak-mini-badge:hover {
  transform: translateX(-50%) translateY(-2px);
  filter: brightness(1.03);
  box-shadow: 0 14px 26px rgba(15, 65, 95, 0.22);
}

.streak-mini-badge:active {
  transform: translateX(-50%) translateY(0);
}

.streak-mini-badge:focus-visible {
  outline: 3px solid rgba(25, 145, 255, 0.45);
  outline-offset: 2px;
}

.streak-mini-badge b {
  font-size: 14px;
  font-weight: 1000;
  letter-spacing: 0.2px;
}

.streak-mini-badge--none {
  background: linear-gradient(135deg, rgba(148, 163, 184, 0.95), rgba(176, 190, 208, 0.95));
}

/* ✅ BRONZE */
.streak-mini-badge--bronze {
  background: linear-gradient(135deg, rgba(184, 115, 51, 0.98), rgba(224, 169, 109, 0.96));
  box-shadow:
    0 10px 22px rgba(184, 115, 51, 0.22),
    0 0 0 4px rgba(224, 169, 109, 0.10);
}

.streak-mini-badge--silver {
  background: linear-gradient(135deg, rgba(148, 163, 184, 0.95), rgba(203, 213, 225, 0.95));
}

/* ✅ GOLD */
.streak-mini-badge--gold {
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.98), rgba(255, 215, 102, 0.98));
  box-shadow:
    0 10px 22px rgba(245, 158, 11, 0.22),
    0 0 0 4px rgba(255, 215, 102, 0.12);
}

.streak-mini-badge--platinum {
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.95), rgba(129, 140, 248, 0.95));
}

/* ✅ DIAMOND glow */
.streak-mini-badge--diamond {
  background: linear-gradient(135deg, rgba(6, 182, 212, 0.98), rgba(59, 130, 246, 0.98));
  box-shadow:
    0 12px 26px rgba(59, 130, 246, 0.25),
    0 0 0 4px rgba(6, 182, 212, 0.16),
    0 0 30px rgba(59, 130, 246, 0.20);
}

/* ✅ LEGENDARY rainbow */
.streak-mini-badge--legendary {
  background: linear-gradient(
    135deg,
    rgba(124, 58, 237, 0.98),
    rgba(37, 99, 235, 0.98),
    rgba(6, 182, 212, 0.98),
    rgba(236, 72, 153, 0.98)
  );
  background-size: 220% 220%;
  animation: legendaryShift 6s ease-in-out infinite;
  box-shadow:
    0 14px 28px rgba(124, 58, 237, 0.22),
    0 0 0 4px rgba(6, 182, 212, 0.14),
    0 0 36px rgba(236, 72, 153, 0.18);
}

/* phone/region mini card */
.profile-mini {
  margin: 14px auto 14px;
  max-width: 320px;

  display: grid;
  grid-template-columns: 1fr 1px 1fr;
  align-items: stretch;

  background: rgba(255, 255, 255, 0.94);
  border: 1px solid rgba(255, 255, 255, 0.98);
  border-radius: 16px;
  box-shadow: 0 14px 30px rgba(6, 30, 58, 0.08);
  overflow: hidden;
}

.profile-mini-divider {
  background: rgba(7, 23, 46, 0.10);
}

.mini-col {
  padding: 12px 12px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.mini-cap {
  display: inline-flex;
  gap: 8px;
  align-items: center;

  font-size: 12px;
  font-weight: 1000;
  letter-spacing: 0.6px;
  color: rgba(7, 23, 46, 0.56);
  text-transform: uppercase;
}

.mini-val {
  font-size: 15px;
  font-weight: 1000;
  color: #07172e;
}

.mini-ico {
  width: 18px;
  height: 18px;
  display: inline-grid;
  place-items: center;
  border-radius: 6px;
  background: rgba(25, 145, 255, 0.18);
  color: rgba(7, 23, 46, 0.86);
}

/* Pills */
.pill {
  width: 100%;
  max-width: 320px;
  margin: 10px auto 0;

  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;

  padding: 12px 14px;
  border-radius: 18px;
  border: 0;

  font-weight: 1000;
  font-size: 14px;
  color: white;

  box-shadow: 0 16px 32px rgba(6, 30, 58, 0.12);
  user-select: none;
}

.pill--teal {
  background: linear-gradient(135deg, rgba(0, 235, 200, 0.99), rgba(25, 145, 255, 0.99));
}

.pill--red {
  background: linear-gradient(135deg, rgba(255, 70, 70, 0.99), rgba(255, 150, 150, 0.98));
}

.pill-icon {
  width: 22px;
  height: 22px;
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.22);
  display: grid;
  place-items: center;
}

/* ===== Streak summary under title (clickable rows) ===== */
.streak-summary-card {
  width: 100%;
  max-width: 320px;
  margin: 12px auto 8px;
  padding: 8px 10px;

  border-radius: 16px;
  background: rgba(255, 255, 255, 0.94);
  border: 1px solid rgba(255, 255, 255, 0.98);
  box-shadow: 0 14px 30px rgba(6, 30, 58, 0.06);
}

.streak-summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}

.streak-summary-row + .streak-summary-row {
  margin-top: 8px;
  padding-top: 8px;
  border-top: 1px solid rgba(7, 23, 46, 0.10);
}

.streak-summary-row--button {
  width: 100%;
  appearance: none;
  -webkit-appearance: none;
  background: transparent;
  border: 0;
  padding: 2px 2px;
  border-radius: 10px;
  cursor: pointer;
  transition: background-color 0.12s ease, transform 0.12s ease;
}

.streak-summary-row--button:hover {
  background: rgba(25, 145, 255, 0.12);
}

.streak-summary-row--button:active {
  transform: scale(0.996);
}

.streak-summary-row--button:focus-visible {
  outline: 2px solid rgba(25, 145, 255, 0.45);
  outline-offset: 2px;
}

.streak-summary-key {
  font-size: 12px;
  font-weight: 1000;
  color: rgba(7, 23, 46, 0.70);
}

.streak-summary-value {
  font-size: 13px;
  font-weight: 1000;
  color: rgba(7, 23, 46, 0.94);
  white-space: nowrap;
}

/* Action buttons */
.action-btn {
  width: 100%;
  max-width: 320px;
  margin: 12px auto 0;

  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;

  padding: 12px 14px;
  border-radius: 18px;
  border: 0;

  font-weight: 1000;
  font-size: 14px;
  cursor: pointer;

  transition: transform 0.12s ease, filter 0.12s ease;
  user-select: none;
  text-decoration: none;
}

.action-btn:hover {
  transform: translateY(-2px);
  filter: brightness(1.04);
}

.action-btn:active {
  transform: translateY(0px);
  filter: brightness(0.98);
}

.action-btn--primary {
  color: white;
  background: linear-gradient(135deg, rgba(0, 235, 200, 0.99), rgba(25, 145, 255, 0.99));
  box-shadow: 0 18px 40px rgba(0, 235, 200, 0.16);
}

.action-btn--soft {
  color: rgba(7, 23, 46, 0.95);
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(25, 145, 255, 0.22);
  box-shadow: 0 16px 30px rgba(6, 30, 58, 0.06);
}

.action-btn--dangerSoft {
  color: white;
  background: linear-gradient(135deg, rgba(255, 70, 70, 0.99), rgba(255, 140, 140, 0.99));
  box-shadow: 0 18px 40px rgba(255, 70, 70, 0.12);
}

/* ===== Right panel sections ===== */
.section {
  border-radius: 22px;
  background: rgba(255, 255, 255, 0.90);
  border: 1px solid rgba(255, 255, 255, 0.98);
  box-shadow: inset 0 0 0 1px rgba(25, 145, 255, 0.08);
  padding: 16px;
}

.section + .section {
  margin-top: 14px;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 10px;

  font-weight: 1000;
  color: rgba(7, 23, 46, 0.92);
  margin: 2px 0 14px;
}

.section-title b {
  color: rgba(0, 210, 185, 1);
}

.section-ico {
  width: 22px;
  height: 22px;
  border-radius: 8px;
  background: rgba(25, 145, 255, 0.18);
  display: grid;
  place-items: center;
}

/* mini stats row */
.mini-stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(160px, 1fr));
  gap: 14px;
}

.mini-stat {
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(255, 255, 255, 0.98);
  box-shadow: 0 14px 30px rgba(6, 30, 58, 0.06);
  padding: 16px 14px;
  text-align: center;
}

.mini-stat-number {
  font-size: 34px;
  font-weight: 1000;
  color: rgba(0, 210, 185, 1);
  line-height: 1;
  margin-bottom: 6px;
}

.mini-stat-label {
  font-size: 12px;
  font-weight: 900;
  color: rgba(7, 23, 46, 0.64);
}

/* progress list */
.progress-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.progress-row {
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(255, 255, 255, 0.98);
  box-shadow: 0 14px 28px rgba(6, 30, 58, 0.06);
  padding: 12px 14px;

  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;

  cursor: pointer;
  transition: transform 0.12s ease, box-shadow 0.12s ease;
}

.progress-row:hover {
  transform: translateY(-2px);
  box-shadow: 0 18px 34px rgba(6, 30, 58, 0.10);
}

.progress-left {
  min-width: 0;
  flex: 1;
}

.progress-type {
  display: inline-flex;
  align-items: center;
  gap: 8px;

  padding: 5px 10px;
  border-radius: 999px;

  font-size: 11px;
  font-weight: 1000;
  letter-spacing: 0.3px;
  margin-bottom: 6px;
  user-select: none;
}

.progress-type--textbook {
  background: rgba(0, 235, 200, 0.18);
  color: rgba(7, 23, 46, 0.92);
}

.progress-type--crossword {
  background: rgba(255, 70, 70, 0.18);
  color: rgba(7, 23, 46, 0.92);
}

.progress-title {
  font-weight: 1000;
  color: rgba(7, 23, 46, 0.94);
  font-size: 15px;
  line-height: 1.2;
  margin-bottom: 3px;
}

.progress-sub {
  font-size: 12px;
  font-weight: 900;
  color: rgba(7, 23, 46, 0.66);
}

.progress-right {
  display: flex;
  align-items: center;
  gap: 12px;
}

.progress-bar {
  width: 180px;
  height: 10px;
  border-radius: 999px;
  background: rgba(7, 23, 46, 0.12);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999px;
  width: 0%;
  background: linear-gradient(90deg, rgba(25, 145, 255, 0.99), rgba(0, 235, 200, 0.99));
  transition: width 0.35s ease;
}

.progress-percent {
  min-width: 44px;
  text-align: right;
  font-weight: 1000;
  color: rgba(0, 210, 185, 1);
}

/* info list */
.info-list {
  margin: 0;
  padding: 0;
  list-style: none;

  display: flex;
  flex-direction: column;
  gap: 10px;
}

.info-li {
  display: flex;
  gap: 10px;
  align-items: flex-start;
  color: rgba(7, 23, 46, 0.78);
  font-weight: 900;
  font-size: 13px;
  line-height: 1.35;
}

.info-bullet {
  width: 18px;
  height: 18px;
  border-radius: 6px;
  background: rgba(25, 145, 255, 0.18);
  display: grid;
  place-items: center;
  flex: 0 0 auto;
  margin-top: 1px;
}

/* ===== Background loading badge ===== */
.background-loading {
  position: fixed;
  top: 18px;
  right: 18px;
  background: rgba(0, 0, 0, 0.65);
  color: white;
  padding: 8px 12px;
  border-radius: 999px;
  font-size: 12px;
  z-index: 1000;
}

.spinner {
  border: 3px solid rgba(255, 255, 255, 0.28);
  border-top: 3px solid rgba(0, 235, 200, 1);
  border-radius: 50%;
  width: 18px;
  height: 18px;
  animation: spin 1.2s linear infinite;
  display: inline-block;
  vertical-align: middle;
  margin-right: 8px;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* ===== Modal form polish (profile edit) ===== */
#profileBody .form-group {
  margin-bottom: 14px;
  text-align: left;
}

#profileBody .form-group label {
  display: block;
  margin-bottom: 6px;
  font-weight: 1000;
  font-size: 13px;
  color: rgba(7, 23, 46, 0.86);
}

#profileBody .form-group input,
#profileBody .form-group select,
#profileBody .form-group textarea {
  width: 100%;
  box-sizing: border-box;
  padding: 12px 14px;
  border-radius: 14px;
  border: 1px solid rgba(25, 145, 255, 0.28);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.62);
  font-weight: 900;
  color: rgba(7, 23, 46, 0.95);
  outline: none;
  transition: border-color 0.15s ease, box-shadow 0.15s ease;
}

#profileBody .form-group input:focus,
#profileBody .form-group select:focus,
#profileBody .form-group textarea:focus {
  border-color: rgba(0, 235, 200, 0.74);
  box-shadow: 0 0 0 4px rgba(0, 235, 200, 0.16);
}

#profileBody .form-group input[disabled],
#profileBody .form-group select[disabled],
#profileBody .form-group textarea[disabled] {
  background: rgba(7, 23, 46, 0.06) !important;
  border-color: rgba(7, 23, 46, 0.14) !important;
  color: rgba(7, 23, 46, 0.55) !important;
  cursor: not-allowed;
}

#profileBody .modal-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  margin-top: 16px;
  flex-wrap: wrap;
  padding-top: 12px;
  border-top: 1px solid rgba(7, 23, 46, 0.12);
}

/* ===== Streak placeholder modal content ===== */
.streak-placeholder-modal {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.streak-placeholder-hero {
  border-radius: 16px;
  padding: 12px;
  color: #fff;
  display: grid;
  grid-template-columns: 46px 1fr;
  gap: 12px;
  align-items: center;
  border: 1px solid rgba(255, 255, 255, 0.35);
  box-shadow: 0 14px 30px rgba(15, 65, 95, 0.12);
}

.streak-placeholder-hero-icon {
  width: 46px;
  height: 46px;
  border-radius: 14px;
  display: grid;
  place-items: center;
  font-size: 22px;
  background: rgba(255, 255, 255, 0.18);
}

.streak-placeholder-hero-main {
  min-width: 0;
}

.streak-placeholder-hero-value {
  font-size: 24px;
  font-weight: 1000;
  line-height: 1;
}

.streak-placeholder-hero-value span {
  font-size: 13px;
  font-weight: 900;
  opacity: 0.95;
}

.streak-placeholder-hero-label {
  margin-top: 5px;
  font-size: 12px;
  font-weight: 900;
  opacity: 0.95;
}

.streak-placeholder-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.streak-placeholder-item {
  border-radius: 14px;
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(255, 255, 255, 0.98);
  box-shadow: 0 12px 24px rgba(6, 30, 58, 0.06);
  padding: 10px 12px;
}

.streak-placeholder-item-key {
  font-size: 11px;
  font-weight: 1000;
  color: rgba(7, 23, 46, 0.58);
}

.streak-placeholder-item-value {
  margin-top: 4px;
  font-size: 14px;
  font-weight: 1000;
  color: rgba(7, 23, 46, 0.95);
  line-height: 1.2;
}

.streak-placeholder-note {
  border-radius: 14px;
  background: rgba(25, 145, 255, 0.10);
  border: 1px dashed rgba(25, 145, 255, 0.26);
  padding: 10px 12px;
  font-size: 12px;
  font-weight: 900;
  color: rgba(7, 23, 46, 0.80);
  line-height: 1.35;
}

/* =======================================================================
   STREAK LEADERBOARD MODAL (Top / Around + highlight "you")
   ======================================================================= */
.streak-leaderboard,
.streak-leaderboard-modal {
  display: grid;
  gap: 12px;
}

.streak-lb-topline {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 10px;
  flex-wrap: wrap;
}

.streak-lb-title {
  font-weight: 1000;
  font-size: 16px;
  letter-spacing: 0.01em;
  color: rgba(7, 23, 46, 0.95);
}

.streak-lb-sub {
  font-size: 12px;
  font-weight: 900;
  color: rgba(7, 23, 46, 0.68);
}

.streak-lb-note {
  border-radius: 14px;
  background: rgba(25, 145, 255, 0.10);
  border: 1px dashed rgba(25, 145, 255, 0.26);
  padding: 10px 12px;
  font-size: 12px;
  font-weight: 900;
  color: rgba(7, 23, 46, 0.82);
  line-height: 1.35;
}

.streak-lb-block {
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(255, 255, 255, 0.98);
  box-shadow: 0 14px 30px rgba(6, 30, 58, 0.06);
  padding: 10px 10px;
}

.streak-lb-head {
  display: grid;
  grid-template-columns: 84px 1fr 1fr;
  gap: 10px;
  padding: 6px 10px 8px;
  font-size: 11px;
  font-weight: 1000;
  letter-spacing: 0.4px;
  color: rgba(7, 23, 46, 0.62);
  text-transform: uppercase;
}

.streak-lb-row {
  display: grid;
  grid-template-columns: 84px 1fr 1fr;
  gap: 10px;
  align-items: center;

  margin-top: 8px;
  padding: 10px 10px;

  border-radius: 14px;
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(25, 145, 255, 0.14);
  box-shadow: 0 12px 24px rgba(6, 30, 58, 0.05);
}

.streak-lb-place {
  font-weight: 1000;
  color: rgba(7, 23, 46, 0.92);
}

.streak-lb-val {
  font-weight: 1000;
  color: rgba(7, 23, 46, 0.92);
}

.streak-lb-hint {
  font-size: 11px;
  font-weight: 900;
  color: rgba(7, 23, 46, 0.62);
  margin-top: 2px;
}

/* highlight "you" */
.streak-lb-row--me {
  background: linear-gradient(135deg, rgba(0, 235, 200, 0.16), rgba(25, 145, 255, 0.16));
  border: 1px solid rgba(0, 210, 185, 0.28);
  box-shadow:
    0 14px 30px rgba(0, 235, 200, 0.08),
    0 0 0 3px rgba(25, 145, 255, 0.10);
}

.streak-lb-youchip {
  display: inline-flex;
  align-items: center;
  gap: 6px;

  padding: 4px 10px;
  border-radius: 999px;

  font-size: 11px;
  font-weight: 1000;
  color: rgba(7, 23, 46, 0.92);
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(25, 145, 255, 0.18);
}

/* loading/error rows */
.streak-lb-state {
  border-radius: 14px;
  padding: 12px 12px;
  font-weight: 900;
  font-size: 13px;
  line-height: 1.35;
}

.streak-lb-state--loading {
  background: rgba(255, 255, 255, 0.72);
  border: 1px solid rgba(255, 255, 255, 0.92);
  color: rgba(7, 23, 46, 0.78);
}

.streak-lb-state--error {
  background: rgba(244, 67, 54, 0.08);
  border: 1px solid rgba(244, 67, 54, 0.18);
  color: #7f1d1d;
}

.streak-lb-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  flex-wrap: wrap;
  margin-top: 10px;
}

@media (max-width: 520px) {
  .streak-lb-head,
  .streak-lb-row {
    grid-template-columns: 70px 1fr 1fr;
  }
}

/* ===== Responsive ===== */
@media (max-width: 980px) {
  .profile-layout {
    grid-template-columns: 1fr;
  }

  .mini-stats {
    grid-template-columns: 1fr;
  }

  .progress-bar {
    width: 140px;
  }

  .streak-placeholder-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 640px) {
  #profileBody .container {
    width: 100%;
    padding: 0 10px;
  }

  .profile-topbar {
    flex-direction: column;
    align-items: stretch;
  }

  .brand {
    justify-content: center;
  }

  .top-actions {
    justify-content: center;
  }

  .streak-chip {
    min-width: 140px;
    height: 50px;
  }

  .progress-row {
    flex-direction: column;
    align-items: stretch;
  }

  .progress-right {
    justify-content: space-between;
  }

  .progress-bar {
    width: 100%;
  }

  .avatar-circle {
    width: 238px;
    height: 238px;
    border-width: 8px;
  }

  .avatar-inner {
    width: 204px;
    height: 204px;
  }

  .avatar-icon-bg {
    inset: 20px;
  }

  /* ✅ на очень узких — чуть крупнее мелкие подписи */
  @media (max-width: 420px) {
    .brand-subtitle,
    .mini-cap,
    .mini-stat-label,
    .progress-sub,
    .info-li,
    .streak-chip-sub {
      font-size: 12.5px;
    }
  }
}

/* =======================================================================
   HIGH-CONTRAST TEXT OVERRIDE (убираем серый/бледно-зелёный, всё читаемо)
   ======================================================================= */
#profileBody{
  --text-strong: #04162f;  /* самый тёмный */
  --text-main:   #07224a;  /* основной текст */
  --text-soft:   #0b3563;  /* подписи/вторичный текст (НЕ серый) */

  --accent-teal: #008a7a;  /* акцент (замена бледно-зелёному) */
  --accent-blue: #0d63ff;  /* акцент-синий */
}

/* Базовый цвет текста в контентных блоках */
.panel,
.profile-card,
.section,
.profile-mini,
.streak-summary-card,
.mini-stat,
.progress-row {
  color: var(--text-main);
}

/* Заголовки/основные строки — максимально читаемо */
.brand-title,
.profile-name,
.section-title,
.progress-title,
.mini-val,
.streak-summary-value,
.info-li b {
  color: var(--text-strong) !important;
}

/* Все “мелкие” подписи — НЕ серые, а тёмно-синие */
.brand-subtitle,
.profile-email,
.mini-cap,
.mini-stat-label,
.progress-sub,
.info-li,
.streak-summary-key,
.section-title,
.progress-type,
.progress-type--textbook,
.progress-type--crossword {
  color: var(--text-soft) !important;
  opacity: 1 !important; /* чтобы не выглядело “в тумане” */
}

/* Акценты: вместо светло-зелёного — насыщенный тёмный teal */
.section-title b,
.mini-stat-number,
.progress-percent {
  color: var(--accent-teal) !important;
}

/* Иконки-квадратики/плашки — чуть контрастнее, но без трогания твоих иконок */
.section-ico,
.mini-ico,
.info-bullet {
  color: var(--text-strong) !important;
}

/* Прогресс-бар фон — чуть темнее, чтобы было видно на ярком фоне */
.progress-bar {
  background: rgba(4, 22, 47, 0.14) !important;
}

/* Текст в карточках прогресса — чётче */
.progress-title { letter-spacing: 0.005em; }
.progress-sub,
.mini-cap,
.brand-subtitle,
.mini-stat-label,
.info-li {
  letter-spacing: 0.015em;
  line-height: 1.38;
}

/* leaderboard text uses the same vars */
.streak-lb-title,
.streak-lb-place,
.streak-lb-val {
  color: var(--text-strong) !important;
}
.streak-lb-sub,
.streak-lb-hint,
.streak-lb-head {
  color: var(--text-soft) !important;
  opacity: 1 !important;
}
