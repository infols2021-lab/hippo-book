<file path="public/styles/base.css">
/* public/styles/base.css */

:root{
  /* Базовая палитра (единая на всех страницах) */
  --bg1: #eaf6ff;
  --bg2: #d8f2ff;

  --accent: #ff6b6b;   /* красный (опасное/выйти) */
  --accent2: #4ecdc4;  /* бирюза (главные действия) */
  --accent3: #74b9ff;  /* голубой (инфо) */

  --card: rgba(255,255,255,0.78);
  --card-border: rgba(255,255,255,0.65);
  --muted:#6b7280;

  /* Единый фон приложения */
  --app-bg-gradient:
    radial-gradient(1200px 800px at 15% 10%, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0) 55%),
    radial-gradient(900px 600px at 85% 15%, rgba(116,185,255,0.25) 0%, rgba(116,185,255,0) 60%),
    linear-gradient(135deg, var(--bg1) 0%, var(--bg2) 45%, #e9fbff 100%);
}

/* ===== Hard reset (фикс “полосок” и лагов) ===== */
*{ box-sizing:border-box }

/* iOS/Android: не даём браузеру самовольно “масштабить” текст */
html{
  -webkit-text-size-adjust: 100%;
  text-size-adjust: 100%;
}

html, body {
  height: 100%;
  margin: 0 !important;
  padding: 0 !important;
  background: #eaf6ff; /* базовый */
}

body{
  min-height:100vh;
  overflow-x: hidden;

  /* ✅ нормальный глобальный шрифт (Poppins из next/font + безопасный фоллбек) */
  font-family: var(--font-sans), system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
               Roboto, "Helvetica Neue", Arial, "Noto Sans", sans-serif;
  font-style: normal;

  color:#1f2937;

  /* фон рисуем отдельным слоем (без background-attachment: fixed) */
  background: transparent;
  position: relative;
  isolation: isolate;
}

/* Формы на мобилках иногда не наследуют шрифт корректно */
button, input, optgroup, select, textarea {
  font-family: inherit;
  font-style: inherit;
}

/* Фиксированный слой фона — не “рвётся” на длинных страницах */
body::before{
  content:"";
  position: fixed;
  inset: 0;
  z-index: -1;
  pointer-events: none;

  background: var(--app-bg-gradient);

  transform: translateZ(0);
  will-change: transform;
}

/* Контейнеры */
.container {
  width:95%;
  max-width:1100px;
  margin:28px auto;
}

/* Simple header */
.header {
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:12px;
  margin-bottom:18px;
}

.logo {
  display:flex;
  gap:12px;
  align-items:center;
}

.logo .mark {
  width:56px;height:56px;border-radius:12px;
  background:linear-gradient(135deg,var(--accent3), rgba(116,185,255,0.55));
  display:flex;align-items:center;justify-content:center;
  font-weight:800;color:#fff;font-size:20px;
  box-shadow:0 10px 24px rgba(15,23,42,0.10);
}

.header .nav { display:flex; gap:8px; align-items:center; }

/* Cards (glass-like) */
.card {
  background: var(--card);
  border-radius:16px;
  padding:18px;
  border: 1px solid var(--card-border);
  box-shadow:0 14px 34px rgba(15,23,42,0.10);
}

/* Blur только на больших экранах (иначе лаги на длинных списках) */
@supports ((-webkit-backdrop-filter: blur(10px)) or (backdrop-filter: blur(10px))) {
  @media (min-width: 1024px) {
    .card {
      -webkit-backdrop-filter: blur(10px);
      backdrop-filter: blur(10px);
    }
  }
}

/* На мобилках/узких экранах делаем карточки более “плотными” */
@media (max-width: 1023px) {
  .card {
    background: rgba(255,255,255,0.92);
  }
}

/* Buttons */
.btn {
  background: linear-gradient(135deg, var(--accent2), #6dd3c0);
  color:#fff;
  border:0;
  padding:10px 16px;
  border-radius:12px;
  font-weight:800;
  cursor:pointer;
  transition: transform .12s ease, box-shadow .12s, filter .12s ease;
  box-shadow:0 10px 18px rgba(78,205,196,0.18);
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}
.btn:hover{ transform:translateY(-3px) }
.btn:active{ transform:translateY(-1px) }

.btn.secondary {
  background: linear-gradient(135deg, var(--accent), #ff8e8e);
  box-shadow:0 10px 18px rgba(255,107,107,0.16);
}

.btn.info {
  background: linear-gradient(135deg, var(--accent3), rgba(116,185,255,0.55));
  box-shadow:0 10px 18px rgba(116,185,255,0.16);
}

.btn.ghost {
  background: rgba(255,255,255,0.55);
  color: var(--accent2);
  border: 2px solid rgba(78,205,196,0.25);
  box-shadow: none;
}

.btn.small { padding:6px 10px; font-size:13px; border-radius:10px }

/* Layout for main pages */
.grid-2 {
  display:grid;
  grid-template-columns: 360px 1fr;
  gap:18px;
}
@media (max-width:880px){
  .grid-2 {
    grid-template-columns: 1fr;
    gap: 12px;
  }
}

/* Profile (общие стили, если где-то используются) */
.profile-card {
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:12px;
  text-align:center;
}

.profile-avatar {
  width:220px;height:220px;border-radius:20px;
  background:linear-gradient(135deg, rgba(255,255,255,0.85), rgba(255,255,255,0.55));
  position:relative;
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 12px 28px rgba(15,23,42,0.10);
  border:6px solid rgba(255,255,255,0.75);
}

/* SVG decorative image container */
.profile-avatar svg { width:100%; height:100%; border-radius:14px; }

/* circles for keys (over image) */
.key-circles { position:absolute; inset:12px; pointer-events:none; }
.key-circle {
  width:34px;height:34px;border-radius:50%;background:#111;opacity:0.9;
  position:absolute; transform:translate(-50%,-50%);
  box-shadow:0 4px 10px rgba(0,0,0,0.3);
}
.key-circle.filled {
  background:linear-gradient(135deg,#ffd166,#ff6b6b);
  box-shadow:0 8px 18px rgba(255,107,107,0.28), 0 2px 6px rgba(0,0,0,0.12);
}

/* positions (7 spots) - placed in friendly arc */
.kpos1{ left:20%; top:28% }
.kpos2{ left:40%; top:16% }
.kpos3{ left:60%; top:14% }
.kpos4{ left:80%; top:26% }
.kpos5{ left:74%; top:54% }
.kpos6{ left:50%; top:66% }
.kpos7{ left:26%; top:58% }

/* Profile info */
.profile-info { width:100%; }
.badge {
  display:inline-block;
  padding:6px 10px;
  border-radius:999px;
  background:var(--accent2);
  color:#fff;
  font-weight:800;
}

/* Admin: controls & lists */
.admin-controls { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:12px; }
.table { width:100%; border-collapse:collapse; margin-top:8px;}
.table th,.table td{
  padding:10px;
  border-bottom:1px solid rgba(15,23,42,0.06);
  text-align:left;
  background: rgba(255,255,255,0.55);
}

/* =========================================================
   MODAL (НЕПРОЗРАЧНАЯ, СО СКРОЛЛОМ, И НОВЫЕ/СТАРЫЕ КЛАССЫ)
   ========================================================= */

/* overlay (новое имя) */
.modal-overlay{
  position: fixed;
  inset: 0;
  z-index: 20000;

  display: flex;
  align-items: center;
  justify-content: center;

  padding: 18px;

  background: rgba(12, 25, 35, 0.55);
}

/* overlay (старое имя) */
.modal-backdrop{
  position:fixed;
  inset:0;
  z-index: 20000;

  display:flex;
  align-items:center;
  justify-content:center;

  padding: 18px;

  background: rgba(12, 25, 35, 0.55);
}

/* panel (новое имя) */
.modal-panel{
  width: 100%;
  border-radius: 22px;

  background: #ffffff; /* НЕПРОЗРАЧНО */
  border: 1px solid rgba(15, 23, 42, 0.14);

  box-shadow:
    0 30px 90px rgba(0, 0, 0, 0.35),
    0 2px 0 rgba(15,23,42,0.04);

  overflow: hidden;
  outline: none;
}

/* content/body (старые имена) */
.modal-content,
.modal-body{
  background: #ffffff !important; /* НЕПРОЗРАЧНО */
}

/* если где-то используется .modal-body как контейнер модалки */
.modal-body{
  width: 100%;
  border-radius: 22px;
  border: 1px solid rgba(15, 23, 42, 0.14);
  box-shadow:
    0 30px 90px rgba(0, 0, 0, 0.35),
    0 2px 0 rgba(15,23,42,0.04);
  overflow: hidden;
}

/* header */
.modal-header{
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;

  padding: 14px 14px;

  background: #f3f6fb; /* НЕПРОЗРАЧНО */
  border-bottom: 1px solid rgba(44, 62, 80, 0.10);
}

.modal-title{
  margin: 0;
  font-size: 16px;
  font-weight: 900;
  color: rgba(44, 62, 80, 0.85);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* close */
.modal-close{
  width: 40px;
  height: 40px;
  border-radius: 14px;
  border: 1px solid rgba(15,23,42,0.10);
  cursor: pointer;

