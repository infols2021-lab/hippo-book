                    </div>

                    <div className="srm-road-side srm-road-side--right">
                      {row.icon ? (
                        <div className="srm-road-card srm-road-card--icon">
                          <div className="srm-road-card-top">
                            <span className="srm-kind-chip srm-kind-chip--icon">🎖️ Иконка</span>
