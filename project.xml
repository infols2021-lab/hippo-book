    padding-top: 90px;
  }
}

@media (max-width: 480px) {
  body.with-fixed-timer {
    padding-top: 100px;
  }
}

/* ===== Score pill (процент рядом со статусом) ===== */
.assignment-status{
  display:flex;
  align-items:center;
  gap:8px;
}

.score-pill{
  display:inline-flex;
