  color: #92400e;
}

.review-badge-skipped {
  background: rgba(107, 114, 128, 0.12);
  color: #374151;
}

.review-correct { border-left: 6px solid rgba(34, 197, 94, 0.55); }
.review-incorrect { border-left: 6px solid rgba(239, 68, 68, 0.55); }
.review-partial { border-left: 6px solid rgba(245, 158, 11, 0.60); }
.review-skipped { border-left: 6px solid rgba(107, 114, 128, 0.55); }

.review-body {
  padding: 14px;
}

.review-block {
  display: grid;
  gap: 6px;
}

.review-label {
  font-size: 12px;
  font-weight: 800;
  color: #6b7280;
  text-transform: uppercase;
  letter-spacing: 0.02em;
}

.review-value {
  font-size: 14px;
  font-weight: 650;
  color: #111827;
  background: #f9fafb;
  border: 1px solid rgba(17,24,39,0.08);
  border-radius: 12px;
  padding: 10px 12px;
  white-space: pre-line;
}

.review-divider {
  height: 1px;
  background: rgba(17,24,39,0.08);
  margin: 12px 0;
}

.review-metrics {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 12px;
}

.review-metric {
  font-size: 12px;
  color: #374151;
  background: #f9fafb;
  border: 1px solid rgba(17,24,39,0.08);
  border-radius: 999px;
  padding: 6px 10px;
}

.review-grid {
  border: 1px solid rgba(17,24,39,0.08);
  border-radius: 14px;
  overflow: hidden;
  background: #fff;
}

.review-grid-head {
  display: grid;
  grid-template-columns: 44px 1fr 1fr;
  gap: 0;
  padding: 10px 12px;
  background: #f9fafb;
  border-bottom: 1px solid rgba(17,24,39,0.08);
  font-size: 12px;
  font-weight: 850;
  color: #6b7280;
}

.review-grid-row {
  display: grid;
  grid-template-columns: 44px 1fr 1fr;
  gap: 0;
  padding: 10px 12px;
  border-bottom: 1px solid rgba(17,24,39,0.06);
  align-items: center;
}

.review-grid-row:last-child {
  border-bottom: none;
}

.review-part-idx {
  font-weight: 900;
  color: #111827;
  font-size: 12px;
}

.review-part-user,
.review-part-correct {
  font-size: 13px;
  font-weight: 650;
  color: #111827;
